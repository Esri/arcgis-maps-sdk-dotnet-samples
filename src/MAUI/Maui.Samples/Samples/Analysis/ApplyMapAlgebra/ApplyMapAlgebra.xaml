<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ArcGIS.Samples.ApplyMapAlgebra.ApplyMapAlgebra"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:esriUI="clr-namespace:Esri.ArcGISRuntime.Maui;assembly=Esri.ArcGISRuntime.Maui">
    <Grid Style="{DynamicResource EsriSampleContainer}">
        <esriUI:MapView x:Name="MyMapView" Style="{DynamicResource EsriSampleGeoView}" />
        <Border Style="{DynamicResource EsriSampleControlPanel}"
                VerticalOptions="Start">
            <Grid>
                <Button x:Name="CategorizeButton"
                        Text="Categorize"
                        IsEnabled="False"
                        MinimumWidthRequest="120"
                        Clicked="OnCategorizeClicked" />
                <VerticalStackLayout x:Name="LayerTogglePanel"
                                     IsVisible="False">
                    <RadioButton x:Name="GeomorphicRadioButton"
                                 Content="Map algebra results"
                                 GroupName="layers"
                                 IsChecked="True"
                                 CheckedChanged="OnRasterLayerSelectionChanged" />
                    <RadioButton x:Name="ElevationRadioButton"
                                 Content="Original elevation raster"
                                 GroupName="layers"
                                 CheckedChanged="OnRasterLayerSelectionChanged" />
                </VerticalStackLayout>
            </Grid>
        </Border>
        <Label Text="Raster data Copyright Scottish Government and SEPA (2014)"
               Grid.RowSpan="2"
               Grid.ColumnSpan="2"
               HorizontalOptions="End"
               VerticalOptions="End"
               Margin="0,0,10,30"
               FontAttributes="Italic"
               FontSize="11"
               TextColor="White" />
    </Grid>
</ContentPage>
